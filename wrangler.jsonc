{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "countdown",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "main": "./src/api/challengeWorker.ts",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "CHALLENGES",
      "id": "placeholder_kv_id"
    }
  ]
}
